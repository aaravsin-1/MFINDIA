# Copy this file to `.env` and fill in your own credentials.
# The real `.env` is git-ignored and must NOT be shared or submitted.

# --- Source database (the amfi_data Postgres the analysis reads from) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=amfi_data
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# --- Supabase (only needed for website/push_to_supabase.py) ---
SUPABASE_HOST=db.your-project.supabase.co
SUPABASE_PORT=5432
SUPABASE_DB=postgres
SUPABASE_USER=postgres
SUPABASE_PASSWORD=your_supabase_password
